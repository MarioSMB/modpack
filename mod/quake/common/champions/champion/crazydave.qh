SOUND(CrazyDave_Pain1, "player_crazydave/pain1");
SOUND(CrazyDave_Pain2, "player_crazydave/pain2");
SOUND(CrazyDave_Pain3, "player_crazydave/pain3");
Sound SND_CrazyDave_Pain_Random() {
    return REGISTRY_GET(Sounds, SND_CrazyDave_Pain1.m_id + rint(random() * 2));
}

