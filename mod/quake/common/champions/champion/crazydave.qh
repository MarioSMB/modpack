#ifdef CSQC
#define CRAZYDAVE_STATS \
"Is crazy\n" \
"Damage taken reduced by 50%\n" \
"Press %ABILITY% to distract"
#endif
CLASS(CrazyDave, Champions)
    ATTRIB(CrazyDave, netname, string, "crazydave");
    ATTRIB(CrazyDave, m_name, string, "Crazy Dave");
    ATTRIB(CrazyDave, qcc_meleename, string, "crazypot");
#ifdef GAMEQC
    ATTRIB(CrazyDave, m_model, Model, MDL_CrazyDave);
    ATTRIB(CrazyDave, m_model_head, Model, MDL_CrazyDave_Head);
    ATTRIB(CrazyDave, m_soundpath, string, "player_crazydave/");
    METHOD(CrazyDave, m_sound_pain, string()) { return SND(CrazyDave_Pain_Random()); }
    METHOD(CrazyDave, m_sound_death, string()) { return SND(CrazyDave_Death_Random()); }
    METHOD(CrazyDave, m_sound_jump, string(entity actor)) { return SND(CrazyDave_Jump_Random()); }
#endif
#ifdef CSQC
    ATTRIB(CrazyDave, m_faceprefix, string, "gfx/quake/crazydave_");
#endif
#ifdef CSQC
    ATTRIB(CrazyDave, message, string, CRAZYDAVE_STATS);
#endif
    ATTRIB(CrazyDave, td_turrets, bool, true);
ENDCLASS(CrazyDave)
REGISTER_CHAMPION(CrazyDave, NEW(CrazyDave));

