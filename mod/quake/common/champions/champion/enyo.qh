#pragma once

#include "../all.qh"

#ifdef GAMEQC
MODEL(Enyo, "progs/player_enyo.mdl");
MODEL(Enyo_Head, "progs/h_player_enyo.mdl");

SOUND(Enyo_Pain1, "player_enyo/pain1");
SOUND(Enyo_Pain2, "player_enyo/pain2");
SOUND(Enyo_Pain3, "player_enyo/pain3");
Sound SND_Enyo_Pain_Random() {
	return REGISTRY_GET(Sounds, SND_Enyo_Pain1.m_id + rint(random() * 2));
}

SOUND(Enyo_Death, "player_enyo/death");

SOUND(Enyo_Jump1, "player_enyo/enyojump1");
SOUND(Enyo_Jump2, "player_enyo/enyojump2");
SOUND(Enyo_Jump3, "player_enyo/enyojump3");
SOUND(Enyo_Jump4, "player_enyo/enyojump4");
Sound SND_Enyo_Jump_Random() {
	return REGISTRY_GET(Sounds, SND_Enyo_Jump1.m_id + rint(random() * 3));
}

SOUND(Enyo_Step1, "player_enyo/foot1");
SOUND(Enyo_Step2, "player_enyo/foot2");
SOUND(Enyo_Step3, "player_enyo/foot3");
SOUND(Enyo_Step4, "player_enyo/foot4");
SOUND(Enyo_Step5, "player_enyo/foot5");
SOUND(Enyo_Step6, "player_enyo/foot6");
SOUND(Enyo_Step7, "player_enyo/foot7");
Sound SND_Enyo_Step_Random() {
	return REGISTRY_GET(Sounds, SND_Enyo_Step1.m_id + rint(random() * 6));
}

SOUND(Enyo_Gasp1, "player_enyo/gasp1");
SOUND(Enyo_Gasp2, "player_enyo/gasp2");
SOUND(Enyo_WaterDeath, "player_enyo/h2odeath");
SOUND(Enyo_AxeHit, "player_enyo/axhit1");
SOUND(Enyo_Land, "player_enyo/land");
SOUND(Enyo_Fall, "player_enyo/land2");

SOUND(Enyo_Burn1, "player_enyo/lburn1");
SOUND(Enyo_Burn2, "player_enyo/lburn2");
Sound SND_Enyo_Burn_Random() {
	return (random() > 0.5) ? SND_Enyo_Burn1 : SND_Enyo_Burn2;
}

SOUND(Enyo_Drown1, "player_enyo/drown1");
SOUND(Enyo_Drown2, "player_enyo/drown2");
Sound SND_Enyo_Drown_Random() {
	return (random() > 0.5) ? SND_Enyo_Drown1 : SND_Enyo_Drown2;
}

SOUND(Enyo_Start1, "player_enyo/taunts/beloved");
SOUND(Enyo_Start2, "player_enyo/taunts/justgettingstarted");
SOUND(Enyo_Start3, "player_enyo/taunts/maniaclaugh");
SOUND(Enyo_Start4, "player_enyo/taunts/scrapeoffthefloor");
SOUND(Enyo_Start5, "player_enyo/taunts/targetlocked");
Sound SND_Enyo_Start_Random() {
	return REGISTRY_GET(Sounds, SND_Enyo_Start1.m_id + rint(random() * 4));
}

SOUND(Enyo_Kill1, "player_enyo/taunts/downboy");
SOUND(Enyo_Kill2, "player_enyo/taunts/didthathurt");
SOUND(Enyo_Kill3, "player_enyo/taunts/dogethis");
SOUND(Enyo_Kill4, "player_enyo/taunts/maniaclaugh");
Sound SND_Enyo_Kill_Random() {
	return REGISTRY_GET(Sounds, SND_Enyo_Kill1.m_id + rint(random() * 3));
}

SOUND(Enyo_Wings_Activate, "player_enyo/wings_got");
SOUND(Enyo_Wings_Charged, "player_enyo/wings");
SOUND(Enyo_Wings_Charged2, "player_enyo/friesdone");

