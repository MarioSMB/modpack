#ifdef CSQC
#define ENYO_STATS \
"Flight meter charges with kills\n" \
"When charged press %ABILITY% to fly\n" \
"Carries two SMGs while flying\n" \
"Damage reduced by 66% in flight\n"
#endif
CLASS(Enyo, Champions)
	ATTRIB(Enyo, netname, string, "enyo");
	ATTRIB(Enyo, m_name, string, "Enyo");
	ATTRIB(Enyo, m_color, vector, '1 0.99 0.82');
	ATTRIB(Enyo, m_viewofs, vector, '0 0 30');
	ATTRIB(Enyo, qcc_meleename, string, "enyosword");
#ifdef GAMEQC
	ATTRIB(Enyo, m_model, Model, MDL_Enyo);
	ATTRIB(Enyo, m_model_head, Model, MDL_Enyo_Head);
	METHOD(Enyo, m_sound_pain, Sound()) { return SND_Enyo_Pain_Random(); }
	METHOD(Enyo, m_sound_death, Sound()) { return SND_Enyo_Death; }
	METHOD(Enyo, m_sound_jump, Sound(entity actor)) { return SND_Enyo_Jump_Random(); }
	METHOD(Enyo, m_sound_waterdeath, Sound(entity actor)) { return SND_Enyo_WaterDeath; }
	METHOD(Enyo, m_sound_gasp1, Sound(entity actor)) { return SND_Enyo_Gasp1; }
	METHOD(Enyo, m_sound_gasp2, Sound(entity actor)) { return SND_Enyo_Gasp2; }
	METHOD(Enyo, m_sound_axehit, Sound(entity actor)) { return SND_Enyo_AxeHit; }
	METHOD(Enyo, m_sound_burn, Sound(entity actor)) { return SND_Enyo_Burn_Random(); }
	METHOD(Enyo, m_sound_drown, Sound(entity actor)) { return SND_Enyo_Drown_Random(); }
	METHOD(Enyo, m_sound_land, Sound(entity actor)) { return SND_Enyo_Land; }
	METHOD(Enyo, m_sound_fall, Sound(entity actor)) { return SND_Enyo_Fall; }
#endif
#ifdef CSQC
	ATTRIB(Enyo, message, string, ENYO_STATS);
#endif
ENDCLASS(Enyo)
REGISTER_CHAMPION(Enyo, NEW(Enyo));

#ifdef SVQC
.float enyo_dodge_time;

.float last_wingbonus;
#endif
