#ifdef CSQC
#define KIRBY_STATS \
"Can fly briefly by double jumping\n" \
"Press %ABILITY% to dash\n" \
"Has Star as only weapon\n" \
"Primary attack varies:\n" \
"- While empty, sucks in enemies\n" \
"- When full, spits out a star\n" \
"  Stronger with more enemies\n" \
"While full, secondary swallows\n" \
"- Heals for 5 per enemy eaten\n" \
"- Gains enemy ability if available\n" \
"Secondary then discards ability\n" \
"Ability overrides primary attack"
#endif
CLASS(Kirby, Champions)
	ATTRIB(Kirby, netname, string, "kirby");
	ATTRIB(Kirby, m_name, string, "Kirby");
	ATTRIB(Kirby, m_color, vector, '0.84 0.28 0.58');
	ATTRIB(Kirby, qcc_noweaponswap, bool, true);
	ATTRIB(Kirby, qcc_falldamage, float, 0);
	ATTRIB(Kirby, qcc_jumpheight, float, 1.15);
	ATTRIB(Kirby, m_viewofs, vector, '0 0 10');
	ATTRIB(Kirby, m_mins, vector, '-10 -10 -24');
	ATTRIB(Kirby, m_maxs, vector, '10 10 11');
#ifdef GAMEQC
	ATTRIB(Kirby, m_model, Model, MDL_Kirby);
	ATTRIB(Kirby, m_model_head, Model, MDL_Null);
	METHOD(Kirby, m_sound_pain, Sound()) { return SND_Kirby_Pain_Random(); }
	METHOD(Kirby, m_sound_death, Sound()) { return SND_Kirby_Death_Random(); }
	METHOD(Kirby, m_sound_waterdeath, Sound(entity actor)) { return SND_Kirby_WaterDeath; }
	METHOD(Kirby, m_sound_gasp1, Sound(entity actor)) { return SND_Kirby_Gasp1; }
	METHOD(Kirby, m_sound_gasp2, Sound(entity actor)) { return SND_Kirby_Gasp2; }
	METHOD(Kirby, m_sound_axehit, Sound(entity actor)) { return SND_Kirby_AxeHit; }
	METHOD(Kirby, m_sound_burn, Sound(entity actor)) { return SND_Kirby_Burn_Random(); }
	METHOD(Kirby, m_sound_drown, Sound(entity actor)) { return SND_Kirby_Drown_Random(); }
	METHOD(Kirby, m_sound_land, Sound(entity actor)) { return SND_Kirby_Land; }
	METHOD(Kirby, m_sound_fall, Sound(entity actor)) { return SND_Kirby_Fall; }
#endif
#ifdef CSQC
	ATTRIB(Kirby, m_faceprefix, string, "gfx/quake/kirby_");
#endif
#ifdef CSQC
	ATTRIB(Kirby, message, string, KIRBY_STATS);
#endif
ENDCLASS(Kirby)
REGISTER_CHAMPION(Kirby, NEW(Kirby));

#ifdef SVQC
.float kirby_bash_time;

.bool kirby_cannon;

bool autocvar_sv_quake_kirby_reset;
#endif

// kirby states, for prediction
const int KIRBY_NORMAL = 0;
const int KIRBY_FULL = 1;
const int KIRBY_FLYING = 2;

void Kirby_PreJump(entity actor);
