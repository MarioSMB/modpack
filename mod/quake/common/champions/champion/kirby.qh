    precache_sound("player_kirby/gasp2.wav");      // taking breath
    precache_sound("player_kirby/h2odeath.wav");       // drowning death

    precache_sound("player_kirby/pain1.wav");
    precache_sound("player_kirby/pain2.wav");

    precache_sound("player_kirby/death1.wav");
    precache_sound("player_kirby/death2.wav");
    precache_sound("player_kirby/death3.wav");
    precache_sound("player_kirby/death4.wav");

    precache_sound("player_kirby/axhit1.wav");
