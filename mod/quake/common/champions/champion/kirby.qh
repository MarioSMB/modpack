#ifdef GAMEQC
MODEL(Kirby, "progs/player_kirby.mdl");

SOUND(Kirby_Pain1, "player_kirby/pain1");
SOUND(Kirby_Pain2, "player_kirby/pain2");
Sound SND_Kirby_Pain_Random() {
	return (random() > 0.5) ? SND_Kirby_Pain1 : SND_Kirby_Pain2;
}

SOUND(Kirby_Death1, "player_kirby/death1");
SOUND(Kirby_Death2, "player_kirby/death2");
SOUND(Kirby_Death3, "player_kirby/death3");
SOUND(Kirby_Death4, "player_kirby/death4");
Sound SND_Kirby_Death_Random() {
	return REGISTRY_GET(Sounds, SND_Kirby_Death1.m_id + rint(random() * 3));
}

SOUND(Kirby_Jump, "player_kirby/plyrjmp8");
SOUND(Kirby_Gasp1, "player_kirby/gasp1");
SOUND(Kirby_Gasp2, "player_kirby/gasp2");
