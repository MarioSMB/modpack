#ifdef CSQC
#define SHANTAE_STATS \
"Press %ABILITY% to transform:\n" \
"- Become Monkey normally\n" \
"- Climbs walls, jumps high\n" \
"- Become Mermaid in water\n" \
"- Shoots bubbles while in water\n" \
"Magic proficiency (-20% cost, +50% damage)\n" \
"Jumps 15% higher\n" \
"Melee hair whip has double range\n" \
"Has Genie Magic as a weapon\n" \
"Right click cycles between spells"
#endif
CLASS(Shantae, Champions)
	ATTRIB(Shantae, netname, string, "shantae");
	ATTRIB(Shantae, m_name, string, "Shantae");
	ATTRIB(Shantae, m_color, vector, '0.51 0.22 0.54');
	ATTRIB(Shantae, qcc_meleename, string, "hair");
	ATTRIB(Shantae, qcc_meleerange, float, 2);
	ATTRIB(Shantae, qcc_jumpheight, float, 1.15);
#ifdef GAMEQC
	ATTRIB(Shantae, m_model, Model, MDL_Shantae);
	ATTRIB(Shantae, m_model_head, Model, MDL_Shantae_Head);
	METHOD(Shantae, m_sound_pain, Sound()) { return SND_Shantae_Pain_Random(); }
	METHOD(Shantae, m_sound_death, Sound()) { return SND_Shantae_Death_Random(); }
	METHOD(Shantae, m_sound_jump, Sound(entity actor)) { return SND_Shantae_Jump; }
	METHOD(Shantae, m_sound_waterdeath, Sound(entity actor)) { return SND_Shantae_WaterDeath; }
	METHOD(Shantae, m_sound_gasp1, Sound(entity actor)) { return SND_Shantae_Gasp1; }
	METHOD(Shantae, m_sound_gasp2, Sound(entity actor)) { return SND_Shantae_Gasp2; }
	METHOD(Shantae, m_sound_axehit, Sound(entity actor)) { return SND_Shantae_AxeHit; }
	METHOD(Shantae, m_sound_burn, Sound(entity actor)) { return SND_Shantae_Burn_Random(); }
	METHOD(Shantae, m_sound_drown, Sound(entity actor)) { return SND_Shantae_Drown_Random(); }
	METHOD(Shantae, m_sound_land, Sound(entity actor)) { return SND_Shantae_Land; }
	METHOD(Shantae, m_sound_fall, Sound(entity actor)) { return SND_Shantae_Fall; }
#endif
#ifdef CSQC
	ATTRIB(Shantae, m_faceprefix, string, "gfx/quake/shantae_");
#endif
#ifdef CSQC
	ATTRIB(Shantae, message, string, SHANTAE_STATS);
#endif
ENDCLASS(Shantae)
REGISTER_CHAMPION(Shantae, NEW(Shantae));

