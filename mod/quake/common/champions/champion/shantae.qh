SOUND(Shantae_Fall, "player_shantae/land2");

SOUND(Shantae_Burn1, "player_shantae/lburn1");
SOUND(Shantae_Burn2, "player_shantae/lburn2");
Sound SND_Shantae_Burn_Random() {
	return (random() > 0.5) ? SND_Shantae_Burn1 : SND_Shantae_Burn2;
}

SOUND(Shantae_Drown1, "player_shantae/drown1");
SOUND(Shantae_Drown2, "player_shantae/drown2");
Sound SND_Shantae_Drown_Random() {
	return (random() > 0.5) ? SND_Shantae_Drown1 : SND_Shantae_Drown2;
}

SOUND(Shantae_Start1, "player_shantae/start1");
SOUND(Shantae_Start2, "player_shantae/start2");
SOUND(Shantae_Start3, "player_shantae/start3");
SOUND(Shantae_Start4, "player_shantae/start4");
SOUND(Shantae_Start5, "player_shantae/start5");
SOUND(Shantae_Start6, "player_shantae/start6");
SOUND(Shantae_Start7, "player_shantae/start7");
