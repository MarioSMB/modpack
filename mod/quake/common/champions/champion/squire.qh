}
#endif
#ifdef CSQC
#define SQUIRE_STATS \
"Movement speed 20% slower\n" \
"Damage taken reduced by 25%\n" \
"Jumps 15% higher\n" \
"Press %ABILITY% to Rage\n" \
"- Double speed while Raging\n" \
"- 50% damage boost while Raging\n" \
"- Killing replenishes Rage\n" \
"- 20 second cooldown when Rage ends"
#endif
CLASS(Squire, Champions)
	ATTRIB(Squire, netname, string, "squire");
	ATTRIB(Squire, m_name, string, "Squire");
	ATTRIB(Squire, m_color, vector, '0.5 0.5 0.5');
	ATTRIB(Squire, qcc_jumpheight, float, 1.15);
	ATTRIB(Squire, qcc_meleename, string, "squireaxe");
#ifdef GAMEQC
	ATTRIB(Squire, m_model, Model, MDL_Squire);
	ATTRIB(Squire, m_model_head, Model, MDL_Squire_Head);
	METHOD(Squire, m_sound_pain, Sound()) { return SND_Squire_Pain_Random(); }
	METHOD(Squire, m_sound_death, Sound()) { return SND_Squire_Death_Random(); }
	METHOD(Squire, m_sound_jump, Sound(entity actor)) { return SND_Squire_Pain_Random(); }
	METHOD(Squire, m_sound_waterdeath, Sound(entity actor)) { return SND_Squire_WaterDeath; }
	METHOD(Squire, m_sound_gasp1, Sound(entity actor)) { return SND_Squire_Gasp1; }
	METHOD(Squire, m_sound_gasp2, Sound(entity actor)) { return SND_Squire_Gasp2; }
	METHOD(Squire, m_sound_axehit, Sound(entity actor)) { return SND_Squire_AxeHit; }
	METHOD(Squire, m_sound_burn, Sound(entity actor)) { return SND_Squire_Burn_Random(); }
	METHOD(Squire, m_sound_drown, Sound(entity actor)) { return SND_Squire_Drown_Random(); }
	METHOD(Squire, m_sound_land, Sound(entity actor)) { return SND_Squire_Land; }
	METHOD(Squire, m_sound_fall, Sound(entity actor)) { return SND_Squire_Fall; }
#endif
#ifdef CSQC
	ATTRIB(Squire, message, string, SQUIRE_STATS);
#endif
	ATTRIB(Squire, td_turrets, bool, true);
ENDCLASS(Squire)
REGISTER_CHAMPION(Squire, NEW(Squire));

#ifdef CSQC
#undef SQUIRE_STATS
#endif

