/* property   */ ATTRIB(KeenUFO, target_range, float, 300);
/* property   */ ATTRIB(KeenUFO, target_range_min, float, 1);
/* property   */ ATTRIB(KeenUFO, target_range_optimal, float, 200);

/* property   */ ATTRIB(KeenUFO, target_select_rangebias, float, 0.25);
