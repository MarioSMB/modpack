/* property   */ ATTRIB(KeenUFO, track_type, float, 0);
/* property   */ ATTRIB(KeenUFO, track_accel_pitch, float, 0.4);
/* property   */ ATTRIB(KeenUFO, track_accel_rot, float, 0.7);
/* property   */ ATTRIB(KeenUFO, track_blendrate, float, 0.2);

/* champion   */ ATTRIB(KeenUFO, m_champion, Champions, CHAMPION_Keen);
#endif

ENDCLASS(KeenUFO)
