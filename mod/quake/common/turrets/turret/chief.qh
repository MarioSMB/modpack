/* property   */ ATTRIB(ChiefHeliblade, shot_volly, float, 0);
/* property   */ ATTRIB(ChiefHeliblade, shot_volly_refire, float, 0);

/* property   */ ATTRIB(ChiefHeliblade, target_range, float, 550);
/* property   */ ATTRIB(ChiefHeliblade, target_range_min, float, 1);
/* property   */ ATTRIB(ChiefHeliblade, target_range_optimal, float, 400);

/* property   */ ATTRIB(ChiefHeliblade, target_select_rangebias, float, 0.25);
