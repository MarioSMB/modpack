/* property   */ ATTRIB(MarioBullsEyeBlaster, target_select_playerbias, float, 1);
/* property   */ ATTRIB(MarioBullsEyeBlaster, target_select_missilebias, float, 0);

/* property   */ ATTRIB(MarioBullsEyeBlaster, aim_firetolerance_dist, float, 120);
/* property   */ ATTRIB(MarioBullsEyeBlaster, aim_speed, float, 100);
/* property   */ ATTRIB(MarioBullsEyeBlaster, aim_maxrot, float, 60);
/* property   */ ATTRIB(MarioBullsEyeBlaster, aim_maxpitch, float, 60);

/* property   */ ATTRIB(MarioBullsEyeBlaster, track_type, float, 1);
/* property   */ ATTRIB(MarioBullsEyeBlaster, track_accel_pitch, float, 0.7);
/* property   */ ATTRIB(MarioBullsEyeBlaster, track_accel_rot, float, 0.4);
/* property   */ ATTRIB(MarioBullsEyeBlaster, track_blendrate, float, 0.2);

/* champion   */ ATTRIB(MarioBullsEyeBlaster, m_champion, Champions, CHAMPION_Mario);
#endif

ENDCLASS(MarioBullsEyeBlaster)
REGISTER_TURRET(BULLSEYE_BLASTER, NEW(MarioBullsEyeBlaster));
