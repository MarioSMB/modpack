#pragma once

// ===========
//  BARRICADE
// ===========

CLASS(RangerBarricade, Turret)
#ifdef GAMEQC
/* spawnflags */ ATTRIB(RangerBarricade, spawnflags, int, TUR_FLAG_NONE);
/* mins       */ ATTRIB(RangerBarricade, m_mins, vector, '-32 -32 0');
/* maxs       */ ATTRIB(RangerBarricade, m_maxs, vector, '32 32 32');
#endif
#ifdef CSQC
/* modelname  */ ATTRIB(RangerBarricade, mdl, string, "progs/tur_barricade.mdl");
/* head_model */ ATTRIB(RangerBarricade, head_model, string, "");
#endif
/* netname    */ ATTRIB(RangerBarricade, netname, string, "barricade");
/* fullname   */ ATTRIB(RangerBarricade, m_name, string, _("Barricade"));
/* description*/ ATTRIB(RangerBarricade, m_description, string, "Damages and pushes back approaching enemies");
#ifdef GAMEQC
/* number     */ ATTRIB(RangerBarricade, impulse, int, 0);
/* cost       */ ATTRIB(RangerBarricade, tur_cost, float, 30);
/* units      */ ATTRIB(RangerBarricade, tur_units, int, 3);
/* health     */ ATTRIB(RangerBarricade, health, float, 700);
/* damage     */ ATTRIB(RangerBarricade, shot_dmg, float, 3);
/* champion   */ ATTRIB(RangerBarricade, m_champion, Champions, CHAMPION_Ranger);
#endif

ENDCLASS(RangerBarricade)
REGISTER_TURRET(BARRICADE, NEW(RangerBarricade));

// ========
//  NAILER
// ========

CLASS(RangerNailer, Turret)
#ifdef GAMEQC
/* spawnflags */ ATTRIB(RangerNailer, spawnflags, int, 0);
/* mins       */ ATTRIB(RangerNailer, m_mins, vector, '-16 -16 0');
/* maxs       */ ATTRIB(RangerNailer, m_maxs, vector, '16 16 32');
/* modelname  */ ATTRIB(RangerNailer, mdl, string, "progs/tur_nailer_base.mdl");
/* head_model */ ATTRIB(RangerNailer, head_model, string, "progs/tur_nailer.iqm");
#endif
/* netname    */ ATTRIB(RangerNailer, netname, string, "nailer");
/* fullname   */ ATTRIB(RangerNailer, m_name, string, _("Nailer"));
/* description*/ ATTRIB(RangerNailer, m_description, string, "Rapidly shoots nearby enemies");
#ifdef GAMEQC
/* number     */ ATTRIB(RangerNailer, impulse, int, 1);
/* cost       */ ATTRIB(RangerNailer, tur_cost, float, 40);
/* units      */ ATTRIB(RangerNailer, tur_units, int, 4);

/* property   */ ATTRIB(RangerNailer, health, float, 200);

/* property   */ ATTRIB(RangerNailer, shot_dmg, float, 6);
/* property   */ ATTRIB(RangerNailer, shot_refire, float, 0.33);
/* property   */ ATTRIB(RangerNailer, shot_spread, float, 0.015);
/* property   */ ATTRIB(RangerNailer, shot_force, float, 20);
/* property   */ ATTRIB(RangerNailer, shot_radius, float, 0);
/* property   */ ATTRIB(RangerNailer, shot_speed, float, 1000);

/* property   */ ATTRIB(RangerNailer, shot_volly, float, 0);
/* property   */ ATTRIB(RangerNailer, shot_volly_refire, float, 0.5);

/* property   */ ATTRIB(RangerNailer, target_range, float, 600);
/* property   */ ATTRIB(RangerNailer, target_range_min, float, 5);
/* property   */ ATTRIB(RangerNailer, target_range_optimal, float, 500);

/* property   */ ATTRIB(RangerNailer, target_select_rangebias, float, 0.25);
/* property   */ ATTRIB(RangerNailer, target_select_samebias, float, 0.25);
/* property   */ ATTRIB(RangerNailer, target_select_anglebias, float, 0.5);
/* property   */ ATTRIB(RangerNailer, target_select_playerbias, float, 1);
/* property   */ ATTRIB(RangerNailer, target_select_missilebias, float, 0);

/* property   */ ATTRIB(RangerNailer, aim_firetolerance_dist, float, 25);
/* property   */ ATTRIB(RangerNailer, aim_speed, float, 120);
/* property   */ ATTRIB(RangerNailer, aim_maxrot, float, 55);
/* property   */ ATTRIB(RangerNailer, aim_maxpitch, float, 55);

/* property   */ ATTRIB(RangerNailer, track_type, float, 3);
/* property   */ ATTRIB(RangerNailer, track_accel_pitch, float, 0.4);
/* property   */ ATTRIB(RangerNailer, track_accel_rot, float, 0.7);
/* property   */ ATTRIB(RangerNailer, track_blendrate, float, 0.2);

/* champion   */ ATTRIB(RangerNailer, m_champion, Champions, CHAMPION_Ranger);
#endif

ENDCLASS(RangerNailer)
REGISTER_TURRET(NAILER, NEW(RangerNailer));

// ========
//  MORTAR
// ========

CLASS(RangerMortar, Turret)
#ifdef GAMEQC
/* spawnflags */ ATTRIB(RangerMortar, spawnflags, int, TUR_FLAG_SPLASH);
/* mins       */ ATTRIB(RangerMortar, m_mins, vector, '-16 -16 0');
/* maxs       */ ATTRIB(RangerMortar, m_maxs, vector, '16 16 32');
