/* property   */ ATTRIB(DukeRocketLauncher, aim_maxrot, float, 55);
/* property   */ ATTRIB(DukeRocketLauncher, aim_maxpitch, float, 55);

/* property   */ ATTRIB(DukeRocketLauncher, track_type, float, 3);
