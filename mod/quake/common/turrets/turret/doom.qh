/* spawnflags */ ATTRIB(DoomCoil, spawnflags, int, 0);
/* mins       */ ATTRIB(DoomCoil, m_mins, vector, '-16 -16 0');
/* maxs       */ ATTRIB(DoomCoil, m_maxs, vector, '16 16 32');
